# Application
APP_NAME="Simple API"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/simple_api
API_BASE_PATH=/simple_api

# Timezone
APP_TIMEZONE=America/Sao_Paulo

# Database Connection — uncomment the one you want to use

# MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simple_api
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL
# DB_CONNECTION=postgresql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=simple_api
# DB_USERNAME=postgres
# DB_PASSWORD=
